---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const recipes = await getCollection('recipes', ({ data }) => !data.hidden);
const dinners = await getCollection('dinners', ({ data }) => data.kind === 'everyday');
dinners.sort((a, b) => (a.data.sortOrder ?? 999) - (b.data.sortOrder ?? 999));
const byCategory = new Map<string, typeof recipes>();
for (const r of recipes) {
  const category = r.id.split('/')[0];
  if (!byCategory.has(category)) byCategory.set(category, []);
  byCategory.get(category)!.push(r);
}
const categoryOrder = [
  'proteins',
  'pasta-and-bakes',
  'sides',
  'sauces-and-seasonings',
  'breakfasts',
  'bread',
  'ninja-creami',
  'desserts',
  'on-trial',
];
const categories = [...byCategory.keys()].sort((a, b) => {
  const ai = categoryOrder.indexOf(a);
  const bi = categoryOrder.indexOf(b);
  return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi) || a.localeCompare(b);
});
const categoryNames: Record<string, string> = {
  proteins: 'Proteins',
  'pasta-and-bakes': 'Pasta & mains',
  sides: 'Sides',
  'sauces-and-seasonings': 'Sauces & seasonings',
  breakfasts: 'Breakfast',
  bread: 'Bread',
  'ninja-creami': 'Ninja Creami',
  desserts: 'Desserts',
  'on-trial': 'On trial',
};
---
<BaseLayout title="Recipes">
  <section class="hero">
    <p class="eyebrow">The house cookbook</p>
    <h1>What are we making tonight?</h1>
    <p class="lede">Start with a complete dinner, or grab one recipe from the library.</p>
  </section>

  <section id="dinners" class="page-section featured-section">
    <div class="section-heading">
      <div><p class="eyebrow">Most used</p><h2>Dinners</h2></div>
      <a href="/dinners">See all dinners →</a>
    </div>
    <div class="dinner-grid">
      {dinners.map((d, index) => (
        <a class="dinner-card" href={`/dinners/${d.slug}`}>
          <span class="card-kicker">Dinner {index + 1} · {d.data.dishes.filter((dish) => !dish.optional).length} core recipes</span>
          <strong>{d.data.title}</strong>
          {d.data.summary && <span>{d.data.summary}</span>}
        </a>
      ))}
    </div>
  </section>

  <section id="recipes" class="page-section">
    <div class="section-heading"><div><p class="eyebrow">Browse individually</p><h2>Recipe library</h2></div></div>
    <nav class="category-nav" aria-label="Recipe categories">
      {categories.map((category) => <a href={`#${category}`}>{categoryNames[category] ?? category}</a>)}
    </nav>
  </section>
  {categories.map((category) => (
    <section id={category} class="recipe-category">
      <h2 class="category">{categoryNames[category] ?? category}</h2>
      <div class="recipe-grid">
        {byCategory.get(category)!
          .sort((a, b) => a.data.title.localeCompare(b.data.title))
          .map((r) => (
            <a class="recipe-card" href={`/recipes/${r.id.replace(/\.md$/, '')}`}>
              <strong>{r.data.title}</strong>
              <span>{r.data.prepTime && `Prep ${r.data.prepTime}`}{r.data.prepTime && r.data.cookTime && ' · '}{r.data.cookTime && `Cook ${r.data.cookTime}`}</span>
            </a>
          ))}
      </div>
    </section>
  ))}
</BaseLayout>
